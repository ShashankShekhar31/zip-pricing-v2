<style>
.zip-pricing-widget {
  border: 1px solid #ddd;
  padding: 20px;
  border-radius: 8px;
  margin-top: 20px;
  background: #fff;
}

.zip-pricing-widget h2 {
  margin-bottom: 15px;
}

#zip-input {
  padding: 10px;
  width: 220px;
  border: 1px solid #ccc;
  border-radius: 4px;
}

#check-price-btn {
  padding: 10px 15px;
  margin-left: 5px;
  border: none;
  background: #000;
  color: white;
  border-radius: 4px;
  cursor: pointer;
}

#check-price-btn:hover {
  opacity: 0.9;
}

#price-result {
  margin-top: 15px;
  font-size: 20px;
  font-weight: bold;
  color: #008060;
}

.zip-pricing-widget h2 {
  margin-bottom: 15px;
  font-size: 32px;
  line-height: 1.2;
}

.zip-pricing-widget {
  max-width: 500px;
}

#check-price-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}
</style>


<div class="zip-pricing-widget">
  <h2>Check Price For Your Area</h2>

  <input
    type="text"
    id="zip-input"
    placeholder="Enter ZIP Code"
  >

  <button id="check-price-btn">
    Check Price
  </button>

  <div id="price-result"></div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const savedZip =
    localStorage.getItem("customerZip");

  if(savedZip){
    document.getElementById("zip-input").value =
      savedZip;
  }

  const button = document.getElementById("check-price-btn");

  button.addEventListener("click", async () => {

    const zip =
      document.getElementById("zip-input").value;

    if (!zip) {
      alert("Enter ZIP Code");
      return;
    }

    if (!/^\d{5}$/.test(zip)) {
      alert("Enter a valid 5-digit ZIP code");
      return;
    }

    try {

      button.disabled = true;
      button.textContent = "Loading...";
      
      const response = await fetch(
        `/apps/zip-pricing?zip=${zip}`
      );

      const data = await response.json();

      localStorage.setItem(
        "customerZip",
        zip
      );

      document.getElementById("price-result").innerHTML =
      `<h3>Price: $${(data.calculatedPrice / 100).toFixed(2)}</h3>`;

      const prices = document.querySelectorAll(".price");

      prices.forEach(price => {
        price.innerHTML =
        `$${(data.calculatedPrice / 100).toFixed(2)}`;
      });

      button.disabled = false;
      button.textContent = "Check Price";

    } catch (error) {

      button.disabled = false;
      button.textContent = "Check Price";

      document.getElementById("price-result").innerHTML =
        "Error fetching price";

      console.error(error);
    }

  });

});
</script>

{% schema %}
{
  "name": "ZIP Pricing Widget",
  "target": "section",
  "settings": []
}
{% endschema %}